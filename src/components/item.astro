---
import dayjs from '../lib/dayjs'
import { getEnv } from '../lib/env'

const locale = getEnv(import.meta.env, Astro, 'LOCALE')
const timezone = getEnv(import.meta.env, Astro, 'TIMEZONE')

locale && dayjs.locale(locale)

const { SITE_URL } = Astro.locals
const { post, isItem } = Astro.props

const channel = getEnv(import.meta.env, Astro, 'CHANNEL')
const COMMENTS = getEnv(import.meta.env, Astro, 'COMMENTS')
const REACTIONS = getEnv(import.meta.env, Astro, 'REACTIONS')

const datetime = dayjs(post.datetime).tz(timezone)
const timeago = datetime.isBefore(dayjs().subtract(1, 'w')) ? datetime.format('HH:mm · ll · ddd') : datetime.fromNow()
const hasContent = post.content.length > 0
const hasReactions = Boolean(REACTIONS && post.reactions?.length > 0)
const hasTags = post.tags.length > 0
const articleClass =
  'group relative mb-5 overflow-hidden rounded-panel border border-line bg-surface-strong p-4 shadow-soft transition duration-200 before:absolute before:inset-y-0 before:left-0 before:w-1 before:bg-[linear-gradient(180deg,var(--color-accent),var(--color-accent-cool))] before:opacity-75 before:content-[""] hover:-translate-y-0.5 hover:border-[rgba(33,27,24,0.22)] hover:shadow-[var(--shadow-hover)] sm:p-5'
const timeBoxClass = 'relative mb-4 flex items-center leading-none'
const timeDotClass =
  'h-[8px] w-[8px] rounded-full bg-accent shadow-[0_0_0_4px_rgba(230,55,70,0.12)] transition group-hover:bg-[var(--color-accent-cool)] group-hover:shadow-[0_0_0_4px_rgba(0,143,131,0.13)]'
const timeTextClass = 'm-0 flex-1 pl-3 text-[12.5px] font-bold uppercase text-muted'
const itemLinkClass = 'text-accent no-underline hover:underline'
const contentClass = 'text-base leading-[1.58]'
const reactionBoxClass = 'pt-3'
const reactionListClass = 'm-0 flex flex-wrap gap-[6px]'
const reactionPillClass =
  'inline-flex items-center gap-1 rounded-full border border-line bg-code py-[3px] pl-[7px] pr-[9px] text-[12px] font-medium text-muted'
const reactionPaidClass = 'border-[rgba(255,196,0,0.35)] bg-[rgba(255,196,0,0.12)] text-[#9a6a00]'
const reactionEmojiClass = 'inline-flex items-center text-[14px] leading-none'
const reactionCountClass = 'font-medium opacity-80 [font-variant-numeric:tabular-nums]'
const tagBoxClass = 'flex flex-wrap items-center gap-2 text-[13px] leading-[1.6]'
const tagPaddingClass = COMMENTS && isItem ? 'pb-3' : 'pb-0'
const tagStandaloneClass = 'pt-3'
const tagLinkClass =
  'inline-block rounded-[4px] border border-line bg-code px-[10px] py-[2px] font-medium text-muted no-underline hover:border-accent hover:bg-surface-strong hover:text-accent hover:no-underline'
const commentsClass = 'pt-3'
const getTagHref = (tag: string) => `/search/result?q=${encodeURIComponent(`#${tag}`)}`
---

<article class={articleClass} style={{ 'view-transition-name': `post-${post.id}` }}>
  <header class={timeBoxClass}>
    <span class={timeDotClass} aria-hidden="true"></span>
    <p class={timeTextClass}>
      <a href={`${SITE_URL}posts/${post.id}`} title={post.datetime} class={itemLinkClass}>
        <time datetime={post.datetime} title={timeago}>{timeago}</time>
      </a>
    </p>
  </header>
  {hasContent && <div class:list={[contentClass, 'content']} set:html={post.content} />}
  {
    hasReactions && (
      <div class:list={[reactionBoxClass, hasContent && '']}>
        <div class={reactionListClass}>
          {post.reactions.map((reaction) => (
            <span class:list={[reactionPillClass, reaction.isPaid && reactionPaidClass]}>
              <span class={reactionEmojiClass}>
                {reaction.isPaid ? (
                  '\u2B50'
                ) : reaction.emojiImage ? (
                  <img
                    src={reaction.emojiImage}
                    alt={reaction.emoji || 'emoji'}
                    loading="lazy"
                    width="20"
                    height="20"
                    class="block h-[1em] w-[1em]"
                  />
                ) : (
                  reaction.emoji
                )}
              </span>
              <span class={reactionCountClass}>{reaction.count}</span>
            </span>
          ))}
        </div>
      </div>
    )
  }
  {
    hasTags && (
      <footer class:list={[tagBoxClass, tagPaddingClass, !hasContent && tagStandaloneClass]}>
        <span class="tag-icon" aria-hidden="true" />
        {post.tags.map((tag: string) => (
          <a href={getTagHref(tag)} title={tag} class={tagLinkClass}>
            {tag}
          </a>
        ))}
      </footer>
    )
  }

  {
    COMMENTS && isItem && (
      <section class={commentsClass} aria-label="Comments">
        {/* Telegram comments are the only intentional client-side JS exception. */}
        <script
          is:inline
          async
          src="https://telegram.org/js/telegram-widget.js"
          data-telegram-discussion={`${channel}/${post.id}`}
          data-comments-limit="50"
          data-colorful="1"
          data-color="454545"
        />
      </section>
    )
  }
</article>
